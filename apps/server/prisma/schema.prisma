generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id             String      @id @default(uuid())
  status         OrderStatus @default(PENDING)
  
  // Delivery info
  customerName   String
  email          String?
  city           String
  phone          String
  address        String
  
  // Order details
  photoCount     Int
  formatId       String
  totalPrice     Float
  shippingCost   Float       @default(2900)
  
  // Storage
  driveFolderId  String?
  receiptFileId  String?
  
  // Rejection
  rejectReason   String?

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Settings {
  id              String   @id @default("global")
  shippingCost    Float    @default(2900)
  nequiNumber     String   @default("3125871829")
  nequiName       String   @default("BOFT COLOMBIA SAS")
  nequiQrDriveId  String?
  nequiQrUrl      String?

  updatedAt       DateTime @updatedAt
}

model Admin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  REJECTED
}

model PriceTier {
  id         String   @id @default(uuid())
  photoCount Int      @unique
  price      Float
  perPhoto   Float
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SupportSession {
  id        String           @id @default(uuid())
  messages  SupportMessage[]
  receipts  Receipt[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model SupportMessage {
  id               String         @id @default(uuid())
  sessionId        String
  session          SupportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role             Role           // 'user' or 'assistant'
  content          String
  requiresReceipt  Boolean        @default(false)
  printCode        String?
  createdAt        DateTime       @default(now())
}

enum Role {
  user
  assistant
}

model Receipt {
  id               String         @id @default(uuid())
  sessionId        String
  session          SupportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  referenceNumber  String         @unique
  amount           Float
  senderName       String?
  receiverName     String?
  date             DateTime?
  status           String         @default("VALIDATED") // VALIDATED, REJECTED, PENDING
  imageUrl         String?
  createdAt        DateTime       @default(now())
}

model PrintCode {
  id          String   @id @default(uuid())
  code        String   @unique
  value       Float    // Costo equivalente, ej: 6000
  isUsed      Boolean  @default(false)
  expiresAt   DateTime // Fecha de vencimiento
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
